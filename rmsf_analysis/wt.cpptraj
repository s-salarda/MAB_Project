# =============================================================================
# CPPTRAJ Script: WT
# =============================================================================
# USAGE: cpptraj -i wt.cpptraj
# =============================================================================

parm      /mnt/d/Projects/MAB_project/Simulations/ChimeraX/1.m.adp.pi_wt_1_2000ns_1000ps.pdb
trajin    /mnt/d/Projects/MAB_project/Simulations/ChimeraX/1.m.adp.pi_wt_1_2000ns_1000ps.dcd 1 500 1

reference /mnt/d/Projects/MAB_project/Simulations/ChimeraX/1.m.adp.pi_wt_1_2000ns_1000ps.pdb [first_ref]

# Strip solvent/ions to speed processing
strip :WAT,Na+,Cl-,Mg2+

# -----------------------------------------------------------------------
# Per-residue RMSF (flexibility profile along the helix)
# -----------------------------------------------------------------------
rmsd align1 @CA&:215-231,266-453,604-621,645-665,472-590 ref [first_ref]
average crdset MyAvg1
run
rmsd average1 @CA&:215-231,266-453,604-621,645-665,472-590 ref MyAvg1
# resinfo :1-853 out wt1_residue_info.dat
atomicfluct out wt1_rmsf.dat :1-9999 byres pdbres
go

